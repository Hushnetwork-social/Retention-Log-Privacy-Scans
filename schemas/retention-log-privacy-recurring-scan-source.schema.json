{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Hushnetwork-social/Retention-Log-Privacy-Scans/schemas/retention-log-privacy-recurring-scan-source.schema.json",
  "title": "Retention Log Privacy Recurring Scan Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "featureId",
    "scanRunId",
    "generatedAt",
    "readinessBaseline",
    "feat137Proof",
    "scannerBaseline",
    "outputFamilies",
    "scanInputs",
    "driftChecks",
    "resultCodes",
    "publicSafetyPolicy",
    "scorePolicy",
    "restrictedEvidencePolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "retention-log-privacy-recurring-scan-source.v1"
    },
    "featureId": {
      "const": "FEAT-164"
    },
    "scanRunId": {
      "type": "string",
      "pattern": "^FEAT164-RLP-SCAN-[0-9]{8}-[0-9]{3}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "readinessBaseline": {
      "$ref": "#/$defs/readinessBaseline"
    },
    "feat137Proof": {
      "$ref": "#/$defs/proofRef"
    },
    "runtimeProofFamily": {
      "$ref": "#/$defs/runtimeProofFamily"
    },
    "scannerBaseline": {
      "$ref": "#/$defs/scannerBaseline"
    },
    "outputFamilies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/outputFamily"
      }
    },
    "scanInputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scanInput"
      }
    },
    "driftChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/driftCheck"
      }
    },
    "resultCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "publicSafetyPolicy": {
      "$ref": "#/$defs/publicSafetyPolicy"
    },
    "scorePolicy": {
      "$ref": "#/$defs/scorePolicy"
    },
    "restrictedEvidencePolicy": {
      "$ref": "#/$defs/restrictedEvidencePolicy"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "publicRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "ref",
        "path"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "hush-documents|PrivateServer_ElectronicVoting|C:\\\\"
          }
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "readinessBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registerVersionId",
        "dimensionId",
        "currentScore",
        "proposedScore",
        "targetBlockerId"
      ],
      "properties": {
        "registerVersionId": {
          "const": "RDY-REG-v0.1.7"
        },
        "dimensionId": {
          "const": "RDY-DIM-008"
        },
        "currentScore": {
          "const": 8
        },
        "proposedScore": {
          "const": 9
        },
        "targetBlockerId": {
          "const": "RDY-BLOCK-INTERNAL_AUDIT_95_DIM008-001"
        }
      }
    },
    "proofRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "packageHash",
        "privacyBoundaryVersion",
        "evidenceStatus",
        "sourceRefs"
      ],
      "properties": {
        "packageId": {
          "type": "string",
          "minLength": 1
        },
        "packageHash": {
          "$ref": "#/$defs/sha256"
        },
        "privacyBoundaryVersion": {
          "type": "string",
          "minLength": 1
        },
        "evidenceStatus": {
          "const": "accepted"
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/publicRef"
          }
        }
      }
    },
    "runtimeProofFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredWhenLiveReportClaimed",
        "currentStatus",
        "proofFamily",
        "allowedStatuses",
        "blockingStatuses"
      ],
      "properties": {
        "requiredWhenLiveReportClaimed": {
          "type": "boolean"
        },
        "currentStatus": {
          "type": "string",
          "minLength": 1
        },
        "proofFamily": {
          "const": "retention_log_privacy"
        },
        "allowedStatuses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockingStatuses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scannerBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scannerVersion",
        "rulesetVersion",
        "forbiddenMaterialCatalogHash",
        "outputFamilyRegistryHash"
      ],
      "properties": {
        "scannerVersion": {
          "type": "string",
          "minLength": 1
        },
        "rulesetVersion": {
          "type": "string",
          "minLength": 1
        },
        "forbiddenMaterialCatalogHash": {
          "$ref": "#/$defs/sha256"
        },
        "outputFamilyRegistryHash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "outputFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "familyId",
        "visibility",
        "scannerDecision",
        "publicPayloadAllowed",
        "allowedPublicFields",
        "forbiddenFields"
      ],
      "properties": {
        "familyId": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "enum": [
            "public",
            "restricted",
            "private"
          ]
        },
        "scannerDecision": {
          "enum": [
            "scan_required",
            "public_safe_summary_only",
            "restricted_ref_only",
            "not_applicable"
          ]
        },
        "publicPayloadAllowed": {
          "type": "boolean"
        },
        "allowedPublicFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scanInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputId",
        "outputFamilyId",
        "sourceRef",
        "expectedVisibility"
      ],
      "properties": {
        "inputId": {
          "type": "string",
          "minLength": 1
        },
        "outputFamilyId": {
          "type": "string",
          "minLength": 1
        },
        "sourceRef": {
          "$ref": "#/$defs/publicRef"
        },
        "expectedVisibility": {
          "enum": [
            "public",
            "restricted",
            "private"
          ]
        }
      }
    },
    "driftCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkId",
        "target",
        "failClosedWhenChanged"
      ],
      "properties": {
        "checkId": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "failClosedWhenChanged": {
          "type": "boolean"
        }
      }
    },
    "publicSafetyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publicOnlyValidation",
        "forbiddenPublicPathPatterns",
        "forbiddenClaimPhrases"
      ],
      "properties": {
        "publicOnlyValidation": {
          "const": true
        },
        "forbiddenPublicPathPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenClaimPhrases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scorePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensionId",
        "proposedScoreFrom",
        "proposedScoreTo",
        "directRegisterMutation"
      ],
      "properties": {
        "dimensionId": {
          "const": "RDY-DIM-008"
        },
        "proposedScoreFrom": {
          "const": 8
        },
        "proposedScoreTo": {
          "const": 9
        },
        "directRegisterMutation": {
          "const": false
        }
      }
    },
    "restrictedEvidencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payloadPublished",
        "publicRefFieldsOnly"
      ],
      "properties": {
        "payloadPublished": {
          "const": false
        },
        "publicRefFieldsOnly": {
          "const": true
        }
      }
    }
  }
}
